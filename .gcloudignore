# ── Cloud Build ignore ──
# This file overrides .gitignore for gcloud builds submit
# so that kg_stats.json and other data files are included

__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
venv-*/
.env

# git
.git/
.gitignore

# Data & raw files
data/db/
.raw_data/
*.zip
*.tar.gz

# PM2 and local config
.pm2/
ecosystem.config.js
logs/
*.log

# Windows specific
Desktop.ini
Thumbs.db

# Agent files
.agent/
.gemini/

# GCP credentials (keep out of build context)
ninetynine-hub-*.json
.agent/*.json

# Scratch
scratch/
